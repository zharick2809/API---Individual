|-- 06.03.  Modificar la ruta de usuario en 'backend/routes/userRoutes.js' con JSDoc: -----------------------------------------------------------------------------------|
|------------------------------------------------------------------------------------------------------------------------------------------------------------------------|

                      1    const express = require('express');
                      2    const router = express.Router();
                      3    const userController = require('../controllers/userController');
                      4    const { verifyToken, authorizeRoles } = require('../middlewares/authMiddleware');
                      5
                      6    /**
                      7     * @swagger
                      8     * tags:
                      9     *   name: Users
                     10     *   description: Gestión de usuarios
                     11     */
                     12
                     13    /**
                     14     * @swagger
                     15     * /api/users/create:
                     16     *   post:
                     17     *     tags: [Users]
                     18     *     summary: Autoregistro
                     19     *     requestBody:
                     20     *       required: true
                     21     *       content:
                     22     *         application/json:
                     23     *           schema:
                     24     *             type: object
                     25     *             required:
                     26     *               - email
                     27     *               - password
                     28     *             properties:
                     29     *               email:
                     30     *                 type: string
                     31     *                 format: email
                     32     *                 description: Email del usuario
                     33     *               name:
                     34     *                 type: string
                     35     *                 description: Nombre del usuario
                     36     *               lastname:
                     37     *                 type: string
                     38     *                 description: Apellido del usuario
                     39     *               role:
                     40     *                 type: string
                     41     *                 enum: [admin, seller, user]
                     42     *                 default: user
                     43     *               password:
                     44     *                 type: string
                     45     *                 format: password
                     46     *                 description: Contraseña del usuario
                     47     *             example:
                     48     *               email: "maria@example.com"
                     49     *               name: "María"
                     50     *               lastname: "García"
                     51     *               password: "password123"
                     52     *     responses:
                     53     *       201:
                     54     *         description: Usuario creado exitosamente
                     55     *         content:
                     56     *           application/json:
                     57     *             schema:
                     58     *               $ref: '#/components/schemas/User'
                     59     *       400:
                     60     *         description: Error en los datos de entrada
                     61     *         content:
                     62     *           application/json:
                     63     *             schema:
                     64     *               $ref: '#/components/schemas/Error'
                     65     */
                     66    router.post('/create', userController.register);
                     67
                     68    /**
                     69     * @swagger
                     70     * /api/users/login:
                     71     *   post:
                     72     *     tags: [Users]
                     73     *     summary: Iniciar sesión
                     74     *     requestBody:
                     75     *       required: true
                     76     *       content:
                     77     *         application/json:
                     78     *           schema:
                     79     *             $ref: '#/components/schemas/Login'
                     80     *     responses:
                     81     *       200:
                     82     *         description: Login exitoso
                     83     *         content:
                     84     *           application/json:
                     85     *             schema:
                     86     *               type: object
                     87     *               properties:
                     88     *                 token:
                     89     *                   type: string
                     90     *                 user:
                     91     *                   $ref: '#/components/schemas/User'
                     92     *       401:
                     93     *         description: Credenciales inválidas
                     94     *         content:
                     95     *           application/json:
                     96     *             schema:
                     97     *               $ref: '#/components/schemas/Error'
                     98     */
                     99    router.post('/login', userController.login);
                    100
                    101    /**
                    102     * @swagger
                    103     * /api/users:
                    104     *   get:
                    105     *     tags: [Users]
                    106     *     summary: Obtener todos los usuarios
                    107     *     security:
                    108     *       - bearerAuth: []
                    109     *     responses:
                    110     *       200:
                    111     *         description: Lista de usuarios obtenida exitosamente
                    112     *         content:
                    113     *           application/json:
                    114     *             schema:
                    115     *               type: array
                    116     *               items:
                    117     *                 $ref: '#/components/schemas/User'
                    118     *       401:
                    119     *         description: No autorizado
                    120     *       403:
                    121     *         description: Prohibido - Sin permisos suficientes
                    122     */
                    123    router.get('/', verifyToken, authorizeRoles(['admin', 'seller']), userController.getAllUsers);
                    124
                    125    /**
                    126     * @swagger
                    127     * /api/users/{id}:
                    128     *   get:
                    129     *     tags: [Users]
                    130     *     summary: Obtener usuario por ID
                    131     *     security:
                    132     *       - bearerAuth: []
                    133     *     parameters:
                    134     *       - in: path
                    135     *         name: id
                    136     *         required: true
                    137     *         schema:
                    138     *           type: integer
                    139     *         description: ID del usuario
                    140     *     responses:
                    141     *       200:
                    142     *         description: Usuario encontrado
                    143     *         content:
                    144     *           application/json:
                    145     *             schema:
                    146     *               $ref: '#/components/schemas/User'
                    147     *       404:
                    148     *         description: Usuario no encontrado
                    149     *       401:
                    150     *         description: No autorizado
                    151     */
                    152    router.get('/:id', verifyToken, authorizeRoles(['admin', 'seller']), userController.getUserById);
                    153
                    154    /**
                    155     * @swagger
                    156     * /api/users:
                    157     *   put:
                    158     *     tags: [Users]
                    159     *     summary: Actualizar usuario
                    160     *     security:
                    161     *       - bearerAuth: [] 
                    162     *     requestBody:
                    163     *       required: true
                    164     *       content:
                    165     *         application/json:
                    166     *           schema:
                    167     *             type: object
                    168     *             properties:
                    169     *               name:
                    170     *                 type: string
                    171     *               email:
                    172     *                 type: string
                    173     *                 format: email
                    174     *               password:
                    175     *                 type: string
                    176     *                 format: password
                    177     *             example:
                    178     *               id: "2"
                    179     *               email: "marinita@modificado.com"
                    180     *               name: "Marinita"
                    181     *               lastname: "Rodríguez"
                    182     *               phone: "3163163161"
                    183     *               image: "yyyy"
                    184     *               password: "12345"
                    185     *     responses:
                    186     *       200:
                    187     *         description: Usuario actualizado exitosamente 
                    188     *       404:
                    189     *         description: Usuario no encontrado
                    190     *       401:
                    191     *         description: No autorizado
                    192     */
                    193    router.put('/', verifyToken, authorizeRoles(['admin', 'seller']), userController.getUserUpdate);
                    194
                    195    /**
                    196     * @swagger
                    197     * /api/users/delete/{id}:
                    198     *   delete:
                    199     *     tags: [Users]
                    200     *     summary: Eliminar usuario
                    201     *     security:
                    202     *       - bearerAuth: []
                    203     *     parameters:
                    204     *       - in: path
                    205     *         name: id
                    206     *         required: true
                    207     *         schema:
                    208     *           type: integer
                    209     *         description: ID del usuario a eliminar
                    210     *     responses:
                    211     *       200:
                    212     *         description: Usuario eliminado exitosamente
                    213     *       404:
                    214     *         description: Usuario no encontrado
                    215     *       401:
                    216     *         description: No autorizado
                    217     *       403:
                    218     *         description: Prohibido - Solo administradores pueden eliminar
                    219     */
                    220    router.delete('/delete/:id', verifyToken, authorizeRoles(['admin']), userController.getUserDelete);
                    221
                    222    module.exports = router;

