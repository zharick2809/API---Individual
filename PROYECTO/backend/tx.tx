|------------------------------------------------------------------------------------------------------------------------------------------------------------------------|
|-- 06.02.  Modificar el código servidor en 'backend/server.js': --------------------------------------------------------------------------------------------------------|
|------------------------------------------------------------------------------------------------------------------------------------------------------------------------|

                      1    // server.js
                      2    const express = require('express');
                      3    const logger = require('morgan');
                      4    const cors = require('cors');
                      5    const swaggerUi = require('swagger-ui-express');
                      6    const swaggerSpec = require('./config/swagger');
                      7    const usersRoutes = require('./routes/userRoutes');
                      8
                      9    const app = express();
                     10
                     11    // Middlewares globales
                     12    app.use(logger('dev'));
                     13    app.use(express.json());
                     14    app.use(express.urlencoded({ extended: true }));
                     15    app.use(cors());
                     16
                     17    // Documentación de swagger
                     18    const swaggerOptions = {  
                     19      swaggerOptions: {
                     20        docExpansion: 'list',           
                     21        defaultModelsExpandDepth: -1,   
                     22        defaultModelExpandDepth: 1,     
                     23        displayRequestDuration: true,   
                     24        filter: false,                  
                     25        layout: 'BaseLayout',  
                     26        showExtensions: true,
                     27        showCommonExtensions: true,
                     28        deepLinking: true,         
                     29        persistAuthorization: true,
                     30        tagsSorter: 'alpha',       
                     31        operationsSorter: function(a, b) {
                     32          const methodOrder = { 'post': 1, 'get': 2, 'put': 3, 'delete': 4 };
                     33          return methodOrder[a.get('method')] - methodOrder[b.get('method')];
                     34        }  
                     35      }  
                     36    };
                     37
                     38    app.use('/api-docs', swaggerUi.serve, swaggerUi.setup(swaggerSpec, swaggerOptions));
                     39
                     40    // Rutas
                     41    app.use('/api/users', usersRoutes);
                     42
                     43    // Endpoints de prueba
                     44    app.get('/', (req, res) => {
                     45        res.send('Ruta raíz del Backend');
                     46    });
                     47
                     48    app.get('/test', (req, res) => {
                     49        res.send('Ruta TEST');
                     50    });
                     51
                     52    // Manejo de errores
                     53    app.use((err, req, res, next) => {
                     54        console.log(err);
                     55        res.status(err.status || 500).send(err.stack);
                     56    });
                     57
                     58    console.log('📚 Swagger disponible en: http://192.168.1.77:3000/api-docs');
                     59
                     60    module.exports = app;

